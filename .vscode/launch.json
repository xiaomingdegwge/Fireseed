{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Fireseed (one-shot)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "pythonArgs": ["-Xfrozen_modules=off"],
      "program": "${workspaceFolder}/app.py",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "PYDEVD_DISABLE_FILE_VALIDATION": "1"
      },
      "args": ["--provider", "mock", "--print", "hello"],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Debug Fireseed (one-shot, Debug Console)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "pythonArgs": ["-Xfrozen_modules=off"],
      "program": "${workspaceFolder}/app.py",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "PYDEVD_DISABLE_FILE_VALIDATION": "1"
      },
      "args": ["--provider", "mock", "--print", "请只输出：PONG"],
      "console": "internalConsole",
      "redirectOutput": true,
      "justMyCode": false
    },
    {
      "name": "Debug Fireseed (interactive)",
